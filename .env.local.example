# ─── R2 Storage (CLI + cron cleanup) ───
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=

# ─── Public URLs ───
NEXT_PUBLIC_R2_PUBLIC_URL=https://pics.milkandhenny.com
# Canonical site URL — used by app + CLI for share links, sitemap, RSS
NEXT_PUBLIC_BASE_URL=https://milkandhenny.com

# ─── Redis / KV (Vercel KV or direct Upstash — one pair needed) ───
KV_REST_API_URL=
KV_REST_API_TOKEN=
REDIS_URL=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── Auth (token-based: verify → JWT, never store credentials) ───
# AUTH_SECRET: JWT signing key. Generate: openssl rand -hex 32.
# Must be at least 32 chars (weak values are rejected at runtime).
AUTH_SECRET=

# ─── Guest list: two gates (both server-verified, not in repo) ───
# STAFF_PIN: PIN to open the guestlist page (door staff). Verify: POST /api/guests/verify-staff-pin
STAFF_PIN=
# ADMIN_PASSWORD: Admin gate for management tools and admin dashboard.
# Short/weak values will show up as warnings in /api/debug (health/status).
# Verify: POST /api/admin/verify
ADMIN_PASSWORD=

# ─── Upload page: dedicated upload gate ───
# UPLOAD_PIN: PIN to access /upload (shareable with non-admin uploaders). Verify: POST /api/upload/verify-pin
UPLOAD_PIN=

# ─── Transfers ───
# TRANSFER_ID_STYLE: "words" (default) = human-readable 3-word combos (velvet-moon-candle)
#                    "random" = 11-char base64url strings
# TRANSFER_ID_STYLE=words

# ─── Media processing (recommended minimum) ───
# local  = no worker, local processing only
# hybrid = local first, worker fallback for hard formats/failures
# worker = queue worker directly for visual files not already browser-prepared
MEDIA_PROCESSOR_MODE=local
# Browser prep is currently most useful for HEIC/HIF only.
NEXT_PUBLIC_TRANSFER_MEDIA_BROWSER_PREP=auto
# Turn worker/queue on only when the Fly worker is deployed and healthy.
TRANSFER_MEDIA_WORKER_ENABLED=0
TRANSFER_MEDIA_QUEUE_ENABLED=0
# Force HEIC/HIF to worker when browser prep did not already convert them.
TRANSFER_MEDIA_FORCE_WORKER_FOR_HEIF=1
TRANSFER_MEDIA_WORKER_WAKE_TOKEN=

# Optional advanced routing knobs (usually leave unset)
# TRANSFER_MEDIA_FORCE_WORKER_FOR_RAW=0
# TRANSFER_MEDIA_FORCE_WORKER_FOR_VIDEO=0
# TRANSFER_MEDIA_WORKER_BATCH_SIZE=8
# TRANSFER_MEDIA_WORKER_POLL_MS=2000
# TRANSFER_MEDIA_WORKER_EMPTY_BACKOFF_MS=10000
# TRANSFER_MEDIA_WORKER_ERROR_BACKOFF_MS=30000

# ─── Cron (required for /api/cron/cleanup-transfers — Vercel cron will 503 without it) ───
# Generate: openssl rand -hex 32. Add to Vercel Environment Variables. Same value in both.
# CRON_SECRET=

# ─── Uptime / health checks ───
# HEALTHCHECK_TOKEN: Protects GET /api/health. Uptime monitors must send header:
#   x-health-token: <HEALTHCHECK_TOKEN>
# Generate: openssl rand -hex 32
# HEALTHCHECK_TOKEN=
