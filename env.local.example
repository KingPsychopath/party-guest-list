# Core persistence (REST Redis / KV)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Direct Redis connection (required for blocking transfer-media worker)
# Prefer REDIS_URL if your provider gives you one.
REDIS_URL=
# Or provide discrete Upstash direct Redis fields instead:
UPSTASH_REDIS_URL=
UPSTASH_REDIS_HOST=
UPSTASH_REDIS_PORT=6379
UPSTASH_REDIS_PASSWORD=
UPSTASH_REDIS_USERNAME=default

# Public file URL
NEXT_PUBLIC_R2_PUBLIC_URL=

# R2 write credentials
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_MAX_SOCKETS=100
R2_SOCKET_ACQUISITION_WARNING_TIMEOUT_MS=10000

# Auth
AUTH_SECRET=
STAFF_PIN=
ADMIN_PASSWORD=
UPLOAD_PIN=

# App URLs / ops
NEXT_PUBLIC_BASE_URL=http://localhost:3000
CRON_SECRET=

# Transfer media worker
MEDIA_PROCESSOR_MODE=hybrid
TRANSFER_MEDIA_WORKER_ENABLED=1
TRANSFER_MEDIA_QUEUE_ENABLED=1
TRANSFER_MEDIA_WORKER_CONCURRENCY=4
TRANSFER_MEDIA_WORKER_ERROR_BACKOFF_MS=15000
TRANSFER_MEDIA_LOCAL_RAW_TIMEOUT_MS=12000
TRANSFER_MEDIA_LOCAL_VIDEO_TIMEOUT_MS=8000
TRANSFER_MEDIA_WORKER_WAKE_URL=https://party-guest-list-transfer-worker.fly.dev/wake
TRANSFER_MEDIA_WORKER_WAKE_TOKEN=
