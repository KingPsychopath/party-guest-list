# Core persistence (REST Redis / KV)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Direct Redis connection (required for blocking transfer-media worker)
# Prefer REDIS_URL if your provider gives you one.
REDIS_URL=
# Or provide discrete Upstash direct Redis fields instead:
UPSTASH_REDIS_URL=
UPSTASH_REDIS_HOST=
UPSTASH_REDIS_PORT=6379
UPSTASH_REDIS_PASSWORD=
UPSTASH_REDIS_USERNAME=default

# Public file URL
NEXT_PUBLIC_R2_PUBLIC_URL=

# R2 write credentials
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_MAX_SOCKETS=100
R2_SOCKET_ACQUISITION_WARNING_TIMEOUT_MS=10000

# Auth
AUTH_SECRET=
STAFF_PIN=
ADMIN_PASSWORD=
UPLOAD_PIN=

# App URLs / ops
NEXT_PUBLIC_BASE_URL=http://localhost:3000
CRON_SECRET=

# Transfer media mode
# local: everything inline
# hybrid: inline JPEG/PNG/GIF/HEIC, queue RAW/video
# worker: queue RAW/video only
MEDIA_PROCESSOR_MODE=hybrid
TRANSFER_MEDIA_WAKE_URL=
TRANSFER_MEDIA_WAKE_TOKEN=

# Cloudflare transfer container only
TRANSFER_MEDIA_WORKER_CONCURRENCY=4
TRANSFER_MEDIA_WORKER_ERROR_BACKOFF_MS=15000

# Optional: multi-file ZIP fallback for non-streaming browsers
NEXT_PUBLIC_MULTI_FILE_ZIP_URL=
NEXT_PUBLIC_MULTI_FILE_ZIP_MODE=auto
